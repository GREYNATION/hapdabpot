{
  "name": "hapdabot",
  "version": "1.0.0",
  "description": "Gravity Claw Telegram Bot",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs'); if(fs.existsSync('src/web')){fs.cpSync('src/web', 'dist/web', {recursive: true});}\"",
    "start": "node dist/index.js",
    "deploy": "npm run build && npm start",
    "typecheck": "tsc --noEmit",
    "bot": "tsx src/bot.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@openrouter/sdk": "^0.9.11",
    "@react-three/drei": "^10.7.7",
    "@supabase/supabase-js": "^2.103.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.11",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^171.4.0",
    "groq-sdk": "^1.1.2",
    "leva": "^0.10.1",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.4",
    "octokit": "^5.0.5",
    "openai": "^4.104.0",
    "puppeteer": "^24.40.0",
    "stripe": "^21.0.1",
    "telegraf": "^4.16.3",
    "twilio": "^5.13.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
